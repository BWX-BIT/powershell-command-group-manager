<Window x:Class="ProcessMonitor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="powershell命令管理器" Height="600" Width="900">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        
        <!-- 左侧：命令组管理 -->
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            
            <!-- 命令组列表 -->
            <StackPanel Grid.Row="0" Margin="10">
                <Label Content="命令组" FontWeight="Bold" Margin="0 0 0 5"/>
                <ListBox x:Name="CommandGroupList" Height="150" SelectionChanged="CommandGroupList_SelectionChanged">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding Name}" Margin="5"/>
                                <TextBlock Text="●" Foreground="{Binding StatusColor}" Margin="5 0" FontSize="12"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
                <StackPanel Orientation="Horizontal" Margin="0 5 0 0">
                    <Button Content="新增命令组" Click="NewCommandGroup_Click" Width="100" Margin="0 0 5 0"/>
                    <Button Content="保存" Click="SaveCommandGroup_Click" Width="80" Margin="0 0 5 0"/>
                    <Button Content="删除" Click="DeleteCommandGroup_Click" Width="80"/>
                </StackPanel>
            </StackPanel>
            
            <!-- 命令配置 -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="10">
                <StackPanel>
                    <Label Content="命令组名称:" Margin="0 0 0 3"/>
                    <TextBox x:Name="GroupNameBox" Width="250" Margin="0 0 0 10"/>
                    
                    <Label Content="启动命令:" Margin="0 0 0 3"/>
                    <TextBox x:Name="StartCommandBox" Width="250" Height="60" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" Margin="0 0 0 10"/>
                    
                    <Label Content="停止命令(可选):" Margin="0 0 0 3"/>
                    <TextBox x:Name="StopCommandBox" Width="250" Height="50" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" Margin="0 0 0 10"/>
                    
                    <Label Content="重启命令(可选):" Margin="0 0 0 3"/>
                    <TextBox x:Name="RestartCommandBox" Width="250" Height="50" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" Margin="0 0 0 10"/>
                </StackPanel>
            </ScrollViewer>
            
            <!-- 操作按钮 -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="10">
                <Button Content="启动" Click="StartButton_Click" Width="80" Margin="0 0 5 0" Background="#4CAF50" Foreground="White"/>
                <Button Content="停止" Click="StopButton_Click" Width="80" Margin="0 0 5 0" Background="#f44336" Foreground="White"/>
                <Button Content="重启" Click="RestartButton_Click" Width="80" Background="#2196F3" Foreground="White"/>
            </StackPanel>
        </Grid>
        
        <!-- 右侧：命令输出 TabControl -->
        <TabControl x:Name="OutputTabControl" Grid.Column="1" Margin="10" SelectionChanged="OutputTabControl_SelectionChanged">
            <TabControl.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding Name}"/>
                        <TextBlock Text="●" Foreground="{Binding StatusColor}" Margin="5 0" FontSize="12"/>
                    </StackPanel>
                </DataTemplate>
            </TabControl.ItemTemplate>
            
            <TabControl.ContentTemplate>
                <DataTemplate>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        
                        <!-- 进程信息 -->
                        <GroupBox Grid.Row="0" Header="运行中进程" Margin="5">
                            <StackPanel Orientation="Horizontal" Margin="5">
                                <TextBlock Text="父PID: " FontWeight="Bold"/>
                                <TextBlock Text="{Binding ParentProcessId}" Foreground="Orange"/>
                                <TextBlock Text=" | " Margin="5 0"/>
                                <TextBlock Text="子进程PID: " FontWeight="Bold"/>
                                <TextBlock Text="{Binding ProcessId}" Foreground="Blue"/>
                                <TextBlock Text=" | " Margin="5 0"/>
                                <TextBlock Text="状态: " FontWeight="Bold"/>
                                <TextBlock Text="{Binding StatusText}" Foreground="Green"/>
                            </StackPanel>
                        </GroupBox>
                        
                        <!-- 命令输出 -->
                        <GroupBox Grid.Row="1" Header="命令输出" Margin="5">
                            <DockPanel>
                                <Button Content="清空" Click="ClearOutputButton_Click" Width="60" Height="25" DockPanel.Dock="Top" HorizontalAlignment="Right" Margin="0 5 0 0"/>
                                <TextBox Text="{Binding Output}" IsReadOnly="True" FontFamily="Consolas" FontSize="12"
                                         VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                                         Background="#1e1e1e" Foreground="#d4d4d4"/>
                            </DockPanel>
                        </GroupBox>
                    </Grid>
                </DataTemplate>
            </TabControl.ContentTemplate>
        </TabControl>
    </Grid>
</Window>
